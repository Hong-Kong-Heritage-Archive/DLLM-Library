    "target": "ES2020",
    "module": "Node16",
    "strict": true,
    "esModuleInterop": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "moduleResolution": "node16",
    "types": [
      "jest"
    ]
  },
  "include": [
